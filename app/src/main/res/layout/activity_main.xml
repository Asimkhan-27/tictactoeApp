<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Game Status -->
    <TextView
        android:id="@+id/statusText"
        android:text="Player X Turn"
        android:textSize="24sp"
        android:layout_margin="20dp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Grid Layout -->
    <GridLayout
        android:rowCount="3"
        android:columnCount="3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- Row 1 -->
        <Button android:id="@+id/btn0" style="@style/gridBtn"/>
        <Button android:id="@+id/btn1" style="@style/gridBtn"/>
        <Button android:id="@+id/btn2" style="@style/gridBtn"/>

        <!-- Row 2 -->
        <Button android:id="@+id/btn3" style="@style/gridBtn"/>
        <Button android:id="@+id/btn4" style="@style/gridBtn"/>
        <Button android:id="@+id/btn5" style="@style/gridBtn"/>

        <!-- Row 3 -->
        <Button android:id="@+id/btn6" style="@style/gridBtn"/>
        <Button android:id="@+id/btn7" style="@style/gridBtn"/>
        <Button android:id="@+id/btn8" style="@style/gridBtn"/>

    </GridLayout>

    <!-- Reset Button -->
    <Button
        android:id="@+id/resetBtn"
        android:text="Restart Game"
        android:textSize="18sp"
        android:layout_marginTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>